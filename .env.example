# --- App URLs (resolved at runtime, never baked at build) --------------------
APP_URL=http://localhost:3000
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# --- Self-host vs hosted SaaS (lib/self-host.ts) -----------------------------
# A "self-host" instance is fully standalone — it does NOT phone home to the
# hosted AgentKitProject ecosystem (Market / managed LLM gateway / Stripe credits
# / *.agentkitproject.com links). HOSTED (the default — all flags unset) behaves
# EXACTLY as before.
#
# SELF-HOST SIGNAL (any of):
#   AUTH_PROVIDER=oidc   implicitly marks the instance self-hosted (see below).
#   SELF_HOST=true       explicit opt-in for an OIDC-less self-host.
# SELF_HOST=false
#
# When self-host:
#   - Market: OFF unless you point AGENTKITMARKET_BASE_URL at your OWN Market
#     (no fallback to the hosted Market — that would be a silent phone-home).
#   - AI: BYO provider key ONLY (no managed/platform-key gateway, no prepaid
#     credits ledger, no Stripe credits UI).
#   - Ecosystem links (*.agentkitproject.com) are HIDDEN unless you set the
#     NEXT_PUBLIC_*_URL overrides below.
#
# DISABLE_MARKET=true forces ALL Market integration off regardless (catalog /
# favorites / import / submit / update-check return a clean disabled response).
# DISABLE_MARKET=true

# Ecosystem link overrides (config-driven; used by the About / Account / Import
# UI). On HOSTED these default to the public properties and need not be set. On
# SELF-HOST an unset link is HIDDEN; set these to point at your own properties.
# NEXT_PUBLIC_PROJECT_URL=https://agentkitproject.com
# NEXT_PUBLIC_FORGE_URL=https://forge.agentkitproject.com
# NEXT_PUBLIC_PROFILE_URL=https://profile.agentkitproject.com
# NEXT_PUBLIC_AUTO_URL=https://auto.agentkitproject.com
# (The Market link follows AGENTKITMARKET_BASE_URL — see "Market integration".)

# --- Auth provider (pluggable) -----------------------------------------------
# Selects the authentication backend (lib/auth-provider/):
#   workos  (default) WorkOS/AuthKit cookie sessions — the hosted SaaS path.
#   oidc              Generic OpenID Connect (Auth Code + PKCE) — self-hosted
#                     (ALSO the implicit self-host signal — see above).
# Hosted instances leave this unset/`workos`; behavior is unchanged.
# AUTH_PROVIDER=workos

# --- WorkOS AuthKit (cookie sessions) — used when AUTH_PROVIDER=workos --------
# Mirrors agentkitmarket-app. Required for login; if unset, the app runs but all
# /api/* routes return 401 (and middleware no-ops).
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# Must be at least 32 chars.
WORKOS_COOKIE_PASSWORD=
# Optional: override the session cookie name.
# WORKOS_COOKIE_NAME=wos-session

# --- Generic OIDC (self-hosted) — used when AUTH_PROVIDER=oidc ----------------
# Authorization Code + PKCE via openid-client; session sealed with iron-session.
# Under oidc, the /api/forge/* device-bearer routes and hosted-Market submit are
# inert (they return 501 / no-op) — they are WorkOS-bound and not used here.
# OIDC_ISSUER=https://idp.example.com/realms/main   # discovery (.well-known) base
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# Defaults to "openid profile email" when unset.
# OIDC_SCOPES=openid profile email
# Defaults to {APP_URL}/auth/callback when unset.
# OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
# Seals the iron-session cookie (>=32 chars). Reuses WORKOS_COOKIE_PASSWORD if unset.
# SESSION_SECRET=
# Optional: override the OIDC session cookie name.
# OIDC_SESSION_COOKIE=akf-oidc-session
# Dev-only: allow http (non-TLS) issuers. NEVER set in production.
# OIDC_ALLOW_INSECURE=false

# --- KitStore backend --------------------------------------------------------
# Selects the KitStore + UserSettingsStore adapter (server/store/index.ts):
#   local    (default) LocalDiskKitStore — needs a persistent volume; works
#                       self-host (k8s PV) but NOT on Amplify (ephemeral FS).
#   aws                 S3 (kit trees) + DynamoDB (metadata, settings). For
#                       hosted/Amplify. Provision with the infra/ CDK stack.
#   selfhost            Postgres (metadata, settings) + MinIO/S3 (kit trees).
KITSTORE_BACKEND=local

# local backend: server data dir for kit trees + metadata + favorites.
AGENTKITFORGE_WEB_DATA_DIR=./.agentkitforge-web-data

# aws backend (KITSTORE_BACKEND=aws) — names output by the infra/ CDK stack:
# DYNAMODB_KITS_TABLE=
# DYNAMODB_SETTINGS_TABLE=
# S3_BUCKET=
# S3_PREFIX=            # optional key prefix within the bucket
# AWS_REGION=us-east-1

# selfhost backend (KITSTORE_BACKEND=selfhost):
# DATABASE_URL=postgres://user:pass@host:5432/agentkitforge_web   # see selfhost-pg.ts
# S3_ENDPOINT=          # MinIO endpoint
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PREFIX=

# Secret for AES-256-GCM at-rest encryption of per-user AI provider API keys
# (server/store/user-settings.ts). A 32-byte hex/base64 key or any passphrase.
# If UNSET, provider keys are stored in PLAINTEXT (a one-time warning is logged).
AGENTKITFORGE_WEB_SECRET=

# --- AI provider (server-side only; never sent to the browser) ---------------
# Per-user providers are configured in-app (Settings) and stored server-side.
# This env var is an optional single-provider FALLBACK for headless/dev use
# when a user has configured no providers of their own.
# JSON blob consumed by /api/drafts/{generate,revise}. Example (Anthropic):
# {"providerType":"anthropic","name":"Anthropic","apiKey":"sk-ant-...","defaultModel":"claude-..."}
# Supported providerType: openai | anthropic | gemini | ollama | openai-compatible
AGENTKITFORGE_AI_PROVIDER_CONFIG=

# --- Gateway managed prepaid-credit inference (Gateway 1b) -------------------
# HOSTED-ONLY: the entire managed path (platform Anthropic key + prepaid-credit
# ledger + /api/gateway/* + /api/managed/models) is OFF on self-host (BYO key is
# the only path there — see "Self-host" above). These vars are ignored on
# self-host. Managed AI: when a user has NO BYO provider configured, drafts run
# on the PLATFORM Anthropic key and debit the user's prepaid credit balance.
# The 4 DynamoDB credit/session tables (deployed) are reached by the same
# FORGE_AWS_* IAM user + region as the aws KitStore adapter.
GATEWAY_CREDIT_ACCOUNTS_TABLE=GatewayCreditAccounts
GATEWAY_CREDIT_TXNS_TABLE=GatewayCreditTxns
GATEWAY_CREDIT_HOLDS_TABLE=GatewayCreditHolds
GATEWAY_SESSIONS_TABLE=GatewaySessions
# PLATFORM Anthropic key for MANAGED turns. UNSET = managed inference errors
# inertly (BYO providers unaffected). Never expose to the browser.
# ANTHROPIC_API_KEY=
# Optional markup in basis points for managed turns (default 1500 = 15%).
# GATEWAY_MARKUP_BPS=1500
# Comma-separated admin emails allowed to call POST /api/credits/dev-grant
# (pre-Stripe testing credit grant). Empty = the dev-grant route is disabled.
# ADMIN_EMAILS=jag8765@gmail.com

# --- AgentKitAuto (Phase A: on-demand autonomous runs) -----------------------
# Two DynamoDB tables back standing approvals + runs (aws/local backend; the
# selfhost backend uses the same Postgres pool as the KitStore instead). Both
# DEFAULT (AutoRuns / AutoApprovals) so the build never breaks if unset. They are
# reached by the SAME FORGE_AWS_* IAM user + region as the KitStore + credit
# ledger. Auto REUSES the platform ANTHROPIC_API_KEY + the GatewayCredit* ledger
# tables above for managed billing (it does not introduce its own billing).
# NOTE: the in-process run dispatcher is DEV / SELF-HOST only; hosted long-running
# execution requires the deferred Fargate / k8s-Job worker (see server/core/auto.ts).
AUTO_RUNS_TABLE=AutoRuns
AUTO_APPROVALS_TABLE=AutoApprovals
# AUTO_SCHEDULES_TABLE (Phase B): standing cron schedules. Defaults to AutoSchedules
# when unset. Created by the infra/ CDK stack; the per-minute EventBridge → Lambda
# sweep hits /api/internal/auto/sweep, which selects due schedules and dispatches
# their runs onto Fargate via the SAME path on-demand runs use.
AUTO_SCHEDULES_TABLE=AutoSchedules
# AUTO_WEBHOOKS_TABLE (Phase C): standing inbound webhook triggers. Defaults to
# AutoWebhooks when unset. Created by the infra/ CDK stack. Stores ONLY the secret
# hash; the public ingest route (/api/hooks/auto/[webhookId]) authenticates each
# fire by the per-webhook secret (the fourth auth path) and dispatches a run via
# the SAME path on-demand runs use.
AUTO_WEBHOOKS_TABLE=AutoWebhooks
# AUTO_INPUTS_BUCKET / AUTO_INPUTS_PREFIX (Phase C): the S3 bucket + prefix backing
# user-provided run input files. Reuses the kit-trees bucket (S3_BUCKET) under an
# auto-inputs/ prefix. The SSR app presigns PUT (upload-url routes); the worker GETs
# during hydration into the run workspace inputs/ dir. When AUTO_INPUTS_BUCKET is
# unset the upload-url route returns 503 (and auto-core falls back to a local store
# for dev/tests). Defaults to S3_BUCKET when unset.
AUTO_INPUTS_BUCKET=
AUTO_INPUTS_PREFIX=auto-inputs/
# Auto BILLING MODEL (server-enforced; both OPTIONAL — sane defaults if unset).
# AUTO_MARKUP_BPS: markup on MANAGED Auto inference, in basis points. Separate
#   from the interactive gateway's GATEWAY_MARKUP_BPS (1500/15%). Default 2500
#   (25%). Applies ONLY to managed turns (platform key + prepaid credits); BYO-key
#   inference is never marked up.
# AUTO_MARKUP_BPS=2500
# AUTO_CLOUD_RUN_CENTS_PER_MIN: per-minute compute fee charged ONLY on BYO + CLOUD
#   (Fargate/hosted) Auto runs — we run their job on our compute but collect no
#   inference markup. NOT charged on managed runs (bundled into the 25%),
#   local/desktop runs, or self-host runs. Default 1 (1¢/min) — a tunable
#   placeholder.
# AUTO_CLOUD_RUN_CENTS_PER_MIN=1

# --- AgentKitAuto HOSTED execution (Fargate per-run worker) ------------------
# These select + configure the HOSTED dispatcher. Without them, Auto runs use the
# in-process dispatcher (dev / self-host; isCloudRun=false). All OPTIONAL — a
# missing value never breaks the build (no preBuild gate); they are baked into
# .env.production by amplify.yml only when set. The ECS ids come from the
# infra/ CDK stack's CfnOutputs (AUTO_ECS_*); WEB_FORGE_INTERNAL_URL is this
# app's own public origin; AUTO_WORKER_SERVICE_KEY is a generated server-only
# secret shared with the worker (NEVER sent to the browser or Forge).
#
# AUTO_DISPATCH: set to "fargate" to dispatch hosted runs to ECS Fargate (only
#   takes effect when KITSTORE_BACKEND=aws). Any other value / unset → in-process.
# AUTO_DISPATCH=fargate
# Cluster name (CfnOutput AUTO_ECS_CLUSTER).
# AUTO_ECS_CLUSTER=
# Task-definition family or ARN (CfnOutput AUTO_ECS_TASK_DEF).
# AUTO_ECS_TASK_DEF=agentkit-auto-worker
# Comma-separated PUBLIC subnet ids the task runs in (CfnOutput AUTO_ECS_SUBNET_IDS).
# AUTO_ECS_SUBNET_IDS=
# Security group id allowing 443 + DNS egress (CfnOutput AUTO_ECS_SECURITY_GROUP_ID).
# AUTO_ECS_SECURITY_GROUP_ID=
# Optional container name override; must match the CDK task def container
# (default "auto-worker"). Only set if you renamed the container.
# AUTO_ECS_CONTAINER_NAME=auto-worker
# Shared service-key (server-only) that authorizes the worker to call the
# internal resolve-context endpoint. Generate a strong random value; set the
# SAME value on the ECS task def (CDK context autoWorkerServiceKey). When UNSET,
# /api/internal/auto/resolve-context returns 503 (endpoint disabled). NEVER
# expose to the browser or Forge.
# AUTO_WORKER_SERVICE_KEY=
# This app's own public origin, used by the worker to reach the internal
# resolve-context endpoint (the worker POSTs to ${WEB_FORGE_INTERNAL_URL}
# /api/internal/auto/resolve-context). Set on the WORKER's ECS task def; here it
# is documented for parity.
# WEB_FORGE_INTERNAL_URL=https://webapp.forge.agentkitproject.com

# AUTO Phase D — result delivery (opt-in email + signed webhook).
# SES_SENDER: the verified-domain from-address the worker's EmailSender sends
# completion notifications from. Must be (a subdomain of) the SES domain identity
# the CDK stack verifies (agentkitproject.com). Optional here (the worker reads it
# off its ECS task def, set via CDK context `sesSender`); documented for parity.
# CAVEAT: a sandbox SES account can only send to VERIFIED recipients — request SES
# production access before delivering to arbitrary user emails.
SES_SENDER=noreply@agentkitproject.com

# --- Stripe prepaid credit top-up (Gateway 1b-ii) ----------------------------
# INERT WITHOUT KEYS: if STRIPE_SECRET_KEY is absent, POST /api/credits/topup
# and POST /api/stripe/webhook return 503 "payments not configured". The build
# and SSR never crash. Set both vars in Amplify env once Stripe keys are ready.
#
# After setting STRIPE_SECRET_KEY, create a Stripe webhook endpoint pointing at:
#   https://webapp.forge.agentkitproject.com/api/stripe/webhook
# Subscribe it to the event: checkout.session.completed
# Put its signing secret in STRIPE_WEBHOOK_SECRET.
#
# Credits are NON-REFUNDABLE and NEVER EXPIRE (per policy).
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Market integration ------------------------------------------------------
# Base URL of the AgentKitMarket app (import / favorites / licensed fetch / submit).
# HOSTED: defaults to the public Market when unset. SELF-HOST: there is NO hosted
# fallback — set this to your OWN Market to enable Market features, or leave unset
# (or DISABLE_MARKET=true) to run with Market fully off. It also drives the "View
# on Market" / "Open Market" links in the UI.
AGENTKITMARKET_BASE_URL=https://market.agentkitproject.com
# WorkOS client id used by the core market client for device/licensed flows.
AGENTKITPROJECT_WORKOS_CLIENT_ID=
# Server-only service key for resolving PROTECTED/paid Market kits over the hosted
# AgentKitAuto worker path (no user session): web-forge calls the market-app
# service licensed-package endpoint with this key + the asserted userId.
# Entitlement is STILL enforced Market-side. Set IDENTICALLY to MARKET_SERVICE_KEY
# on agentkitmarket-app. OPTIONAL — when unset, protected Market kits cannot run
# over the worker (the run is refused); local + free kits are unaffected. Distinct
# from AUTO_WORKER_SERVICE_KEY (worker↔web-forge). Never log it; never browser.
# Generate with `openssl rand -hex 32`.
MARKET_SERVICE_KEY=

# --- Build ------------------------------------------------------------------
# Set BUILD_STANDALONE=1 ONLY for the self-host Docker image (next standalone).
# Leave unset for a normal/Amplify build.
# BUILD_STANDALONE=1
