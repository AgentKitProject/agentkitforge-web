# --- App URLs (resolved at runtime, never baked at build) --------------------
APP_URL=http://localhost:3000
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# --- WorkOS AuthKit (cookie sessions) ----------------------------------------
# Mirrors agentkitmarket-app. Required for login; if unset, the app runs but all
# /api/* routes return 401 (and middleware no-ops).
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# Must be at least 32 chars.
WORKOS_COOKIE_PASSWORD=
# Optional: override the session cookie name.
# WORKOS_COOKIE_NAME=wos-session

# --- KitStore backend --------------------------------------------------------
# Selects the KitStore + UserSettingsStore adapter (server/store/index.ts):
#   local    (default) LocalDiskKitStore — needs a persistent volume; works
#                       self-host (k8s PV) but NOT on Amplify (ephemeral FS).
#   aws                 S3 (kit trees) + DynamoDB (metadata, settings). For
#                       hosted/Amplify. Provision with the infra/ CDK stack.
#   selfhost            Postgres (metadata, settings) + MinIO/S3 (kit trees).
KITSTORE_BACKEND=local

# local backend: server data dir for kit trees + metadata + favorites.
AGENTKITFORGE_WEB_DATA_DIR=./.agentkitforge-web-data

# aws backend (KITSTORE_BACKEND=aws) — names output by the infra/ CDK stack:
# DYNAMODB_KITS_TABLE=
# DYNAMODB_SETTINGS_TABLE=
# S3_BUCKET=
# S3_PREFIX=            # optional key prefix within the bucket
# AWS_REGION=us-east-1

# selfhost backend (KITSTORE_BACKEND=selfhost):
# DATABASE_URL=postgres://user:pass@host:5432/agentkitforge_web   # see selfhost-pg.ts
# S3_ENDPOINT=          # MinIO endpoint
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PREFIX=

# Secret for AES-256-GCM at-rest encryption of per-user AI provider API keys
# (server/store/user-settings.ts). A 32-byte hex/base64 key or any passphrase.
# If UNSET, provider keys are stored in PLAINTEXT (a one-time warning is logged).
AGENTKITFORGE_WEB_SECRET=

# --- AI provider (server-side only; never sent to the browser) ---------------
# Per-user providers are configured in-app (Settings) and stored server-side.
# This env var is an optional single-provider FALLBACK for headless/dev use
# when a user has configured no providers of their own.
# JSON blob consumed by /api/drafts/{generate,revise}. Example (Anthropic):
# {"providerType":"anthropic","name":"Anthropic","apiKey":"sk-ant-...","defaultModel":"claude-..."}
# Supported providerType: openai | anthropic | gemini | ollama | openai-compatible
AGENTKITFORGE_AI_PROVIDER_CONFIG=

# --- Market integration ------------------------------------------------------
# Base URL of the AgentKitMarket app (import / favorites / licensed fetch).
AGENTKITMARKET_BASE_URL=https://market.agentkitproject.com
# WorkOS client id used by the core market client for device/licensed flows.
AGENTKITPROJECT_WORKOS_CLIENT_ID=

# --- Build ------------------------------------------------------------------
# Set BUILD_STANDALONE=1 ONLY for the self-host Docker image (next standalone).
# Leave unset for a normal/Amplify build.
# BUILD_STANDALONE=1
